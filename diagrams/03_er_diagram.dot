digraph SocGuardER {
    graph [
        label="SocGuard — Entity-Relationship Diagram\nPostgreSQL: socguard_db"
        labelloc="t"
        fontname="Helvetica-Bold"
        fontsize=16
        bgcolor="#0a0e17"
        fontcolor="white"
        pad=1
        rankdir=TB
    ]
    node [fontname="Courier" shape=record style="filled" fontcolor="white" fontsize=11]
    edge [fontname="Helvetica" fontsize=9 fontcolor="#94a3b8" color="#2d3748"]

    // ─── Main Entity ───
    ALERTS [
        label="{ALERTS (primary persisted table) | \
id : INTEGER PK AUTOINCREMENT | \
content_id : VARCHAR UNIQUE NOT NULL | \
timestamp : DATETIME NOT NULL | \
platform : VARCHAR NOT NULL | \
threat_category : VARCHAR NOT NULL | \
severity_score : FLOAT NOT NULL | \
reasoning : TEXT | \
original_url : TEXT | \
audio_url : TEXT | \
content_type : VARCHAR | \
original_text : TEXT | \
explanation_image : TEXT (Base64 LIME) | \
author : VARCHAR | \
is_resolved : BOOLEAN DEFAULT FALSE}"
        fillcolor="#1e3a5f"
        color="#00f3ff"
    ]

    // ─── Logical Entities ─── 
    PLATFORM [
        label="{PLATFORM (logical entity) | \
platform_name : VARCHAR | \
source_type : ENUM(telegram, bluesky, email, youtube)}"
        fillcolor="#111625"
        color="#2d3748"
    ]

    CONTENT_EVENT [
        label="{CONTENT_EVENT (Kafka Message Schema) | \
content_id : VARCHAR PK | \
timestamp : DATETIME | \
platform : VARCHAR | \
content_type : ENUM(text, image, audio, video) | \
content : TEXT | \
image_url : TEXT or Base64 | \
audio_url : TEXT | \
original_url : VARCHAR | \
author_id : VARCHAR | \
author_username : VARCHAR | \
is_verified : BOOLEAN | \
is_bot : BOOLEAN}"
        fillcolor="#0d2a1a"
        color="#00ff9d"
    ]

    ANALYSIS_RESULT [
        label="{ANALYSIS_RESULT (intermediate, not persisted) | \
content_id : VARCHAR FK | \
threat_label : VARCHAR | \
severity_score : FLOAT | \
reasoning : TEXT | \
explanation_image : TEXT (LIME overlay) | \
analyzer_type : ENUM(text, image, audio, metadata)}"
        fillcolor="#2d2a00"
        color="#ff9900"
    ]

    // ─── Relationships ───
    PLATFORM       -> CONTENT_EVENT  [label="1 : N\n(platform emits many events)"]
    CONTENT_EVENT  -> ANALYSIS_RESULT [label="1 : N\n(one event, multiple analyzers)" style=dashed]
    ANALYSIS_RESULT -> ALERTS         [label="1 : 1\n(each analysis produces one alert row)" style=dashed]
}
