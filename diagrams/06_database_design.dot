digraph SocGuardDB {
    graph [
        label="SocGuard — Database Design\nPostgreSQL 15 — socguard_db"
        labelloc="t"
        fontname="Helvetica-Bold"
        fontsize=16
        bgcolor="#0a0e17"
        fontcolor="white"
        pad=1
        rankdir=LR
    ]
    node [fontname="Courier" fontsize=10 fontcolor="white"]
    edge [fontname="Helvetica" fontsize=9 color="#2d3748" fontcolor="#94a3b8"]

    // ─── Alerts Table ───
    ALERTS [
        shape=record
        label="{ ALERTS | \
id : SERIAL PRIMARY KEY | \
content_id : VARCHAR(255) UNIQUE NOT NULL | \
timestamp : TIMESTAMP NOT NULL | \
platform : VARCHAR(100) NOT NULL | \
threat_category : VARCHAR(100) NOT NULL | \
severity_score : FLOAT NOT NULL | \
reasoning : TEXT | \
original_url : TEXT | \
audio_url : TEXT | \
content_type : VARCHAR(50) | \
original_text : TEXT | \
explanation_image : TEXT (Base64 JPEG LIME) | \
author : VARCHAR(255) | \
is_resolved : BOOLEAN DEFAULT FALSE }"
        fillcolor="#1e3a5f"
        color="#00f3ff"
    ]

    // ─── Enforced Indexes ───
    IDX_CONTENT [
        shape=note
        label="UNIQUE INDEX\ncontent_id\n(deduplication on INSERT)"
        fillcolor="#2d2a00"
        color="#ff9900"
        fontcolor="#ff9900"
    ]

    // ─── Recommended Indexes ───
    IDX_TS [
        shape=note
        label="RECOMMENDED INDEX\ntimestamp DESC\n(pagination ORDER BY)"
        fillcolor="#111625"
        color="#555555"
        fontcolor="#888888"
    ]

    IDX_SEV [
        shape=note
        label="RECOMMENDED INDEX\nseverity_score\n(high-severity stats filter)"
        fillcolor="#111625"
        color="#555555"
        fontcolor="#888888"
    ]

    IDX_PLAT [
        shape=note
        label="RECOMMENDED INDEX\nplatform\n(platform filter views)"
        fillcolor="#111625"
        color="#555555"
        fontcolor="#888888"
    ]

    // ─── Constraints ───
    CONSTRAINTS [
        shape=note
        label="Constraints:\n content_id UNIQUE (dedup)\n timestamp NOT NULL\n threat_category NOT NULL\n severity_score NOT NULL\n is_resolved DEFAULT FALSE"
        fillcolor="#0d2a1a"
        color="#00ff9d"
        fontcolor="white"
    ]

    // ─── Data Type Notes ───
    DTYPES [
        shape=note
        label="Column Notes:\n explanation_image = Base64 JPEG\n  (LIME overlay, can be large)\n content_type in {text, image,\n  audio, metadata, video}\n platform in {telegram, bluesky,\n  email, youtube, reddit_sim}\n severity_score range: 0.0 to 100.0\n is_resolved: false until analyst\n  manually marks it"
        fillcolor="#1a2133"
        color="#00f3ff"
        fontcolor="white"
    ]

    // ─── Threat Category Values ───
    CATEGORIES [
        shape=note
        label="threat_category values:\n Phishing Link\n Threatening Language\n Hate Speech\n Abusive Language\n Harassment\n Offensive Language\n Safe Content\n Confirmed Deepfake Image\n Suspected Deepfake Image\n Authentic Image\n Suspected Deepfake Audio\n Authentic Audio\n Confirmed Bot Account\n Suspected Bot Account\n Legitimate Account"
        fillcolor="#2d1a00"
        color="#ff9900"
        fontcolor="white"
    ]

    ALERTS -> IDX_CONTENT  [label="enforced"]
    ALERTS -> IDX_TS       [label="recommended"]
    ALERTS -> IDX_SEV      [label="recommended"]
    ALERTS -> IDX_PLAT     [label="recommended"]
    ALERTS -> CONSTRAINTS  [label="rules"]
    ALERTS -> DTYPES       [label="notes"]
    ALERTS -> CATEGORIES   [label="domain values"]
}
